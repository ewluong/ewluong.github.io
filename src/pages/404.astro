---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Eric Luong" description="Page not found on ewluong.os">
  <div class="not-found">
    <div class="not-found-inner">
      <span class="designation">ERR.404</span>
      <h1>SIGNAL LOST</h1>
      <p class="message">The requested resource could not be located within the system.</p>
      <a href="/" class="return-link">← Return to ewluong.os</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0a14;
    font-family: 'VT323', monospace;
  }

  .not-found-inner {
    text-align: center;
    max-width: 400px;
  }

  .designation {
    font-size: 13px;
    color: #a07a38;
    letter-spacing: 0.12em;
    display: block;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2rem;
    color: #d4a044;
    letter-spacing: 0.1em;
    margin: 0 0 1rem;
    text-shadow: 0 0 12px rgba(212, 160, 68, 0.3);
  }

  .message {
    font-size: 1rem;
    color: #6a6d82;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .return-link {
    font-size: 0.9rem;
    color: #6a6d82;
    text-decoration: none;
    letter-spacing: 0.06em;
    padding: 0.5rem 1.5rem;
    border: 1px solid #2a2c3a;
    transition: color 150ms, border-color 150ms;
  }

  .return-link:hover {
    color: #d4a044;
    border-color: #a07a38;
  }
</style>
