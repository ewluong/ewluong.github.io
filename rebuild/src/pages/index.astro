---
/**
 * index.astro — The OS entry point.
 * Fetches content collection metadata at build time and passes it to Workspace.
 * Includes a crawlable identity block for SEO (visually hidden, fully accessible to search engines).
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import BootSequence from '../components/BootSequence.svelte';
import Workspace from '../components/Workspace.svelte';
import { getCollection } from 'astro:content';

// Fetch blog metadata (HTML rendered separately as fragment pages)
const blogCollection = await getCollection('blog');
const blogEntries = blogCollection
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((entry) => ({
    slug: entry.id,
    title: entry.data.title,
    date: entry.data.date.getFullYear().toString(),
    tags: entry.data.tags ?? [],
  }));

// Fetch project metadata
const projectCollection = await getCollection('projects');
const projectEntries = projectCollection.map((entry) => ({
  slug: entry.id,
  title: entry.data.title,
  type: entry.data.type,
  tech: entry.data.tech ?? [],
  github: entry.data.github ?? '',
  link: entry.data.link ?? '',
  dataFile: entry.data.dataFile ?? '',
}));
---

<BaseLayout title="Eric Luong — ewluong.os">
  <BootSequence client:load />
  <Workspace
    client:load
    blogEntries={blogEntries}
    projectEntries={projectEntries}
  />

  <!-- Crawlable identity block: invisible to users, fully readable by search engines -->
  <div class="seo-identity" aria-hidden="true">
    <h1>Eric Luong</h1>
    <p>Data scientist, writer, and builder. Personal operating system for essays, projects, and experiments in data science, philosophy, cognition, and technology.</p>

    <h2>About Eric Luong</h2>
    <p>Eric Luong is a data scientist at Vanguard with a background in cognitive science from UC Berkeley and business analytics from Santa Clara University. His work spans machine learning, data analysis, interactive systems, and philosophical writing.</p>

    <h2>Essays by Eric Luong</h2>
    <ul>
      {blogEntries.map((entry) => (
        <li><a href={`/fragments/blog/${entry.slug}/`}>{entry.title}</a> ({entry.date})</li>
      ))}
    </ul>

    <h2>Projects by Eric Luong</h2>
    <ul>
      {projectEntries.map((entry) => (
        <li><a href={`/fragments/projects/${entry.slug}/`}>{entry.title}</a></li>
      ))}
    </ul>

    <h2>Connect</h2>
    <ul>
      <li><a href="https://www.linkedin.com/in/ewluong/" rel="me">Eric Luong on LinkedIn</a></li>
      <li><a href="https://github.com/ewluong" rel="me">Eric Luong on GitHub</a></li>
    </ul>
  </div>
</BaseLayout>

<style>
  /* Visually hidden but fully crawlable by search engines */
  .seo-identity {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
